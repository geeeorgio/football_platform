generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat   = "cjs"
}

datasource db {
  provider = "postgresql"
}


model User {
  id                  String         @id @default(cuid(2))
  email               String         @unique
  username            String         @unique
  passwordHash        String         @map("password_hash")
  avatarUrl           String?        @map("avatar_url")
  role                Role           @default(USER)
  points              Int            @default(0)

  predictions         Prediction[]
  favoriteTeams       FavoriteTeam[]
  predictionComments  PredictionComment[]
  newsComments        NewsComment[]

  createdAt           DateTime       @default(now())      @map("created_at")
  updatedAt           DateTime       @updatedAt           @map("updated_at")

  @@map("users")
}

model Team {
  id           String        @id @default(cuid(2))
  externalId   String        @unique @map("external_id")

  name         String
  logoUrl      String?       @map("logo_url")

  homeMatches  Match[]       @relation("HomeTeam")
  awayMatches  Match[]       @relation("AwayTeam")
  favoriteBy   FavoriteTeam[]

  @@map("teams")
}

model FavoriteTeam {
  userId       String        @map("user_id")
  teamId       String        @map("team_id")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  team         Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([userId, teamId])
  @@map("favorite_teams")
}

model Match {
  id            String      @id @default(cuid(2))
  externalId    String      @unique @map("external_id")

  homeTeamId    String      @map("home_team_id")
  awayTeamId    String      @map("away_team_id")
  homeTeam      Team        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam      Team        @relation("AwayTeam", fields: [awayTeamId], references: [id])

  leagueId      String      @map("league_id")
  league        League      @relation(fields: [leagueId], references: [id])

  startAt       DateTime    @map("start_at")
  status        GameStatus
  homeScore     Int?        @map("home_score")
  awayScore     Int?        @map("away_score")

  predictions   Prediction[]

  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt      @map("updated_at")

  @@map("matches")
}

model League {
  id            String      @id @default(cuid(2))
  externalId    String      @unique @map("external_id")

  name          String
  country       String
  logoUrl       String?     @map("logo_url")
  season        Int
  matches       Match[]

  @@map("leagues")
}

model Prediction {
  id            String            @id @default(cuid(2))
  userId        String            @map("user_id")
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchId       String            @map("match_id")
  match         Match             @relation(fields: [matchId], references: [id], onDelete: Cascade)

  homeScore     Int               @map("home_score")
  awayScore     Int               @map("away_score")
  status        PredictionStatus  @default(PENDING)
  text          String?
  likes         Int               @default(0)
  dislikes      Int               @default(0)
  comments      PredictionComment[]

  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt      @map("updated_at")

  @@map("predictions")
}

model NewsItem {
  id          String    @id @default(cuid(2))
  title       String
  summary     String?
  url         String    @unique
  imageUrl    String?   @map("image_url")
  source      String
  comments    NewsComment[]
  publishedAt DateTime  @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("news_items")
}

model PredictionComment {
  id            String      @id @default(cuid(2))
  userId        String      @map("user_id")
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  predictionId  String      @map("prediction_id")
  prediction    Prediction  @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  text          String
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt      @map("updated_at")

  @@map("prediction_comments")
}

model NewsComment {
  id          String    @id @default(cuid(2))
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  newsItemId  String    @map("news_item_id")
  newsItem    NewsItem  @relation(fields: [newsItemId], references: [id], onDelete: Cascade)
  text        String
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt      @map("updated_at")

  @@map("news_comments")
}

enum Role {
  ADMIN
  USER

  @@map("enum_user_role")
}

enum GameStatus {
  IDLE
  LIVE
  FINISHED
  CANCELLED
  POSTPONED

  @@map("enum_game_status")
}

enum PredictionStatus {
  PENDING
  WIN
  LOSS

  @@map("enum_prediction_status")
}
