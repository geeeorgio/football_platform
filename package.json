{
  "name": "football",
  "private": true,
  "version": "1.0.0",
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "api:dev": "yarn workspace @football/api start:dev",
    "web:dev": "yarn workspace @football/web dev",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:restart": "docker compose restart",
    "db:logs": "docker compose logs -f",
    "db:status": "docker ps"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "engines": {
    "node": "24.x"
  }
}
